# Copy this file to .env and edit values as needed.
# The real .env is ignored by git.

# =========================
# DATABASE (MariaDB)
# =========================
# Used by the backend to connect to the MariaDB container on the compose network.
MYSQL_USER=myuser
MYSQL_DATABASE=transcendence
MYSQL_HOST=db
MYSQL_PORT=3306

# Passwords are provided via secrets files (not via .env):
# - ../secrets/db_password.txt
# - ../secrets/db_root_password.txt

# =========================
# BACKEND (NestJS)
# =========================
BACKEND_PORT=3000

# =========================
# FRONTEND (SvelteKit)
# =========================
FRONTEND_PORT=5173
VITE_API_URL=https://localhost:3000
