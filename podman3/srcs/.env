# =========================
# DATABASE (MariaDB)
# =========================
MYSQL_USER=myuser
MYSQL_DATABASE=transcendence

# Nota: las contraseñas ahora van en secrets
# db_password y db_root_password → archivos en ../secrets/

# =========================
# BACKEND (NestJS)
# =========================
BACKEND_PORT=3000

# Para NestJS: url completa de MariaDB (sin password, lo lee desde el secret)
DATABASE_URL=mysql://${MYSQL_USER}:mypassword@db:3306/${MYSQL_DATABASE}
# ⚠️ La palabra 'secret' es solo un placeholder, NestJS debe leer /run/secrets/db_password

# =========================
# FRONTEND (SvelteKit)
# =========================
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3000
