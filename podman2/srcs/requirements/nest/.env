# =========================
# DATABASE (PostgreSQL)
# =========================
POSTGRES_USER=transcendence
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=transcendence
POSTGRES_HOST=postgres_db
POSTGRES_PORT=5432

# =========================
# BACKEND (NestJS)
# =========================
BACKEND_PORT=3000
# URL completa para ORM (Prisma / TypeORM)
DATABASE_URL=postgres_db://myuser:mypassword@db:5432/transcendence

# =========================
# FRONTEND (SvelteKit)
# =========================
FRONTEND_PORT=5173
VITE_API_URL=http://svelte_frontend:3000

# =========================
# OPTIONAL (PRO)
# =========================
NODE_ENV=development
