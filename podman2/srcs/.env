# =========================
# DATABASE (PostgreSQL)
# =========================
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=transcendence
POSTGRES_HOST=db
POSTGRES_PORT=5432

# =========================
# BACKEND (NestJS)
# =========================
BACKEND_PORT=3000

# URL completa para ORM (Prisma / TypeORM)
DATABASE_URL=postgresql://myuser:mypassword@db:5432/transcendence

# =========================
# FRONTEND (SvelteKit)
# =========================
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3000

# =========================
# OPTIONAL (PRO)
# =========================
NODE_ENV=development
